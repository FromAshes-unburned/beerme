# Beer Me Backend Environment Variables
# Copy to .env and fill in real values

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/beerme

# Auth
JWT_SECRET=your_long_random_secret_here_at_least_64_chars

# Stripe — get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio — for SMS notifications
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Google Maps — for geocoding and routing
GOOGLE_MAPS_API_KEY=AIza...

# App config
APP_NAME=Beer Me
PLATFORM_FEE_PERCENT=12
DELIVERY_FEE_DEFAULT=4.00
MIN_ORDER_DEFAULT=12.00
